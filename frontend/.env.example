# Leave NEXT_PUBLIC_API_URL blank to use the same-origin Next.js proxy at /api/analyze.
# This is best for LAN testing because other devices only need access to the frontend port.
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=http://localhost:5000
NEXT_PUBLIC_BUG_REPORT_EMAIL=bugs@shivpatel.net
NEXT_PUBLIC_BUG_REPORT_ISSUE_URL=https://github.com/shivp1505/PhishGuard/issues/new
